#fi

# yaziの設定
function y() {
  local tmp="$(mktemp -t "yazi-cmd.XXXXXX)")" cwd
  yazi = "$@" --cwd-file="$tmp"
  if cwd="$(command cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
    builtin cd "$cwd"
  fi

  rm -f -- "$tmp"
}
